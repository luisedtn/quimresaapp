generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int       @id @default(autoincrement())
  name       String?
  pass       String?
  photo      String?
  tiempo     Int?
  typeuser   Int?
  permisos   Int?
  idcliente  Int?
  autorizado Boolean?  @default(true)
  cliente    Cliente?  @relation(fields: [idcliente], references: [CODIGO])

  @@map("usuarios")
}

model Cliente {
  CODIGO     Int       @id @default(autoincrement())
  NOMBRE     String?
  NIF        String?
  PAIS       String?
  DIRECCION  String?
  POBLACION  String?
  CP         String?
  PROVINCIA  String?
  TELEFONO   String?
  FAX        String?
  MOVIL      String?
  CONTACTO   String?
  LOGO       String?
  OBS        String?
  DESCUENTO  Float?    @db.Real
  PORCENTAJE Decimal?  @db.Decimal
  ACTIVO     Decimal?  @db.Decimal
  autorizado Boolean?  @default(true)
  usuarios   Usuario[]
  formulas   FormPersonales[]

  @@map("CLIENTES")
}

