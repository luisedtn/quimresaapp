model Marca {
  ID         Int       @id @default(autoincrement())
  NOMBRE     String?   @db.VarChar(255)
  ESPECIAL   Int?      @default(0)
  PREFIJO    String?   @db.VarChar(50)
  formulas   Formula[]

  @@map("MARCAS")
}

model Carta {
  ID         Int       @id @default(autoincrement())
  CARTA      String?   @db.VarChar(255)
  CODIGO     String?   @db.VarChar(50)
  FICHERO    String?   @db.VarChar(255)
  FORMATO    String?   @db.VarChar(50)
  LONGITUD   Int?
  METALIZADA Int?      @default(0)
  STANDARD   Int?      @default(0)
  formulas   Formula[]

  @@map("CARTAS")
}

model Producto {
  ID         Int       @id @default(autoincrement())
  PRODUCTO   String?   @db.VarChar(255)
  UNIDAD     String?   @db.VarChar(50)
  DESCRIPCIO String?
  AGUA       Int?      @default(0)
  MARCA      Int?
  formulas   Formula[]

  @@map("PRODUCTOS")
}

