rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isUserEmail(email) { return isSignedIn() && request.auth.token.email == email; }
    
    // User profile access
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Measurements access
    match /mediciones/{medicionId} {
      // For prototype: allow read if we have an identifier (auth or email)
      allow read: if isSignedIn() || request.query.limit <= 100; 
      // For prototype: allow create without strict auth check
      allow create: if true;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Formulas access
    match /formulas/{formulaId} {
      allow read: if true;
      allow write: if false; 
    }
  }
}
